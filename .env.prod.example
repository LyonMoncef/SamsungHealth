# === Phase 6 — .env.prod template ===
# Spec : docs/vault/specs/2026-04-30-phase6-cicd-mvp.md §6
#
# Usage :
#   cp .env.prod.example .env.prod
#   # remplir les valeurs <replace>
#   chmod 600 .env.prod          # R-H1 — durcissement VPS
#   chown app:app .env.prod      # owner = user qui run docker compose
#
# Génération SAMSUNGHEALTH_ENCRYPTION_KEY (V2.2 AES-256-GCM, BYTEA at-rest) :
#   python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
#
# Génération SAMSUNGHEALTH_JWT_SECRET (V2.3 HS256) :
#   python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
#
# Génération SAMSUNGHEALTH_EMAIL_HASH_SALT (32 bytes hex) :
#   python -c "import secrets; print(secrets.token_hex(32))"

# === Postgres (host = nom du service compose, accès interne docker network) ===
POSTGRES_USER=samsung
POSTGRES_PASSWORD=<replace>
POSTGRES_DB=samsunghealth
DATABASE_URL=postgresql+psycopg://samsung:<replace>@postgres:5432/samsunghealth

# === Image tag ===
# Géré par deploy-*.yml (sed -i sur .env.prod après pull). Pin manuel possible.
# Format requis : dev-<sha40> (set par deploy-dev.yml) ou prod-<sha40> (set par deploy-prod.yml)
# Ne JAMAIS laisser ce placeholder en prod — docker-compose fail explicite si IMAGE_TAG est unset.
IMAGE_TAG=REPLACE_ME_WITH_DEV_OR_PROD_SHA_TAG

# === V2.2.x — Crypto at-rest (CRITIQUE — SAUVEGARDER HORS DU REPO) ===
# Sans cette clé, les colonnes Art.9 RGPD sont irrécupérables.
SAMSUNGHEALTH_ENCRYPTION_KEY=<replace>

# === V2.3 — Auth foundation (JWT + admin-gated registration) ===
SAMSUNGHEALTH_JWT_SECRET=<replace>
# Optionnel — secret précédent pour rotation (decode-only, jamais sign).
SAMSUNGHEALTH_JWT_SECRET_PREVIOUS=
# Token statique requis dans header X-Registration-Token de POST /auth/register.
# Si absent, le endpoint répond 403 (registration_disabled).
SAMSUNGHEALTH_REGISTRATION_TOKEN=<replace>

# === V2.3.1 — Email hashing (lookup déterministe + protection PII) ===
SAMSUNGHEALTH_EMAIL_HASH_SALT=<replace>
# Si true, /auth/login refuse les comptes non vérifiés.
SAMSUNGHEALTH_REQUIRE_EMAIL_VERIFICATION=true

# === V2.3.2 — Google OAuth (laisser vide pour désactiver le bouton SSO) ===
SAMSUNGHEALTH_GOOGLE_OAUTH_CLIENT_ID=
SAMSUNGHEALTH_GOOGLE_OAUTH_CLIENT_SECRET=
# Liste blanche des return_to acceptés (CSV). MUST inclure le domaine prod.
SAMSUNGHEALTH_OAUTH_RETURN_TO_ALLOWED=https://samsunghealth.example
# Si false, OAuth login échoue pour les emails sans compte préexistant.
SAMSUNGHEALTH_OAUTH_AUTO_REGISTER=false

# === V2.3.3.x — Runtime hardening (proxy / HTTPS / rate-limit) ===
SAMSUNGHEALTH_PUBLIC_BASE_URL=https://samsunghealth.example
SAMSUNGHEALTH_ENV=prod
# CSV des proxies de confiance (réécriture X-Forwarded-For). Adapter selon reverse-proxy VPS.
SAMSUNGHEALTH_TRUSTED_PROXIES=127.0.0.1,::1
SAMSUNGHEALTH_FORCE_HTTPS=true

# === V2.3.3.1 — Rate-limit / lockout (overrides optionnels, defaults code suffisent) ===
# SAMSUNGHEALTH_RL_API_POST_CAP=
# SAMSUNGHEALTH_RL_EMAIL_COMPOSITE_CAP=
# SAMSUNGHEALTH_RL_ADMIN_PROBE_GLOBAL_CAP=
# SAMSUNGHEALTH_RL_LRU_CAP=
# SAMSUNGHEALTH_EMAIL_GLOBAL_CAP=
# SAMSUNGHEALTH_EMAIL_GLOBAL_CAP_WINDOW_HOURS=

# === Déploiement multi-instance (info pour /readyz / metrics) ===
# Override > 1 si plusieurs replicas web derrière LB.
SAMSUNGHEALTH_DEPLOYMENT_INSTANCES=1

# === Logging (V2.0.5 structlog) ===
# APP_ENV=prod  → JSONL stdout (capté par docker logs / Loki).
# APP_ENV=dev   → ConsoleRenderer humain.
APP_ENV=prod
LOG_LEVEL=INFO
