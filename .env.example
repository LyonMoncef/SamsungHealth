# V2.2 — Clé maître chiffrement at-rest (AES-256-GCM, BYTEA storage applicatif)
#
# Génération :
#   python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
#
# ⚠️ SAUVEGARDER HORS DU REPO. Sans cette clé, les données chiffrées sont irrécupérables.
# ⚠️ NE PAS COMMITER ce fichier renseigné. `.env` est gitignored — copier en `.env` local.
SAMSUNGHEALTH_ENCRYPTION_KEY=

# Postgres (défaut local docker-compose, override pour cloud)
DATABASE_URL=postgresql+psycopg://samsung:samsung@localhost:5432/samsunghealth

# V2.0.5 — Observability (structlog)
# APP_ENV=dev      → ConsoleRenderer humain (couleurs). Default si non défini : prod (JSONL stdout).
# LOG_LEVEL=INFO   → DEBUG | INFO | WARNING | ERROR | CRITICAL. Invalide → fallback INFO.
# APP_ENV=dev
# LOG_LEVEL=INFO

# V2.3 — Auth foundation (JWT HS256 + admin-gated registration)
#
# JWT secret (≥ 32 chars ASCII OU ≥ 32 bytes base64-decoded).
# Génération :
#   python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
SAMSUNGHEALTH_JWT_SECRET=
# Optionnel — secret précédent pour rotation (decode-only, jamais sign).
SAMSUNGHEALTH_JWT_SECRET_PREVIOUS=
# Token statique requis dans header X-Registration-Token de POST /auth/register.
# Si absent, le endpoint répond 403 (registration_disabled).
SAMSUNGHEALTH_REGISTRATION_TOKEN=
